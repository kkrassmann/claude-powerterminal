{
  "name": "@kkrassmann/claude-powerterminal",
  "version": "1.2.0",
  "description": "Multi-session terminal manager for Claude CLI with status monitoring",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.json && cp electron/analysis/audit-prompt.md dist/electron/analysis/",
    "build:angular": "cd src && npm run build",
    "build": "npm run build:electron && npm run build:angular",
    "start:electron": "npm run build:electron && electron .",
    "start:angular": "cd src && npm start",
    "dev": "concurrently \"npm run start:angular\" \"npm run start:electron\"",
    "test": "vitest run",
    "check:imports": "node scripts/check-package-imports.mjs",
    "predist": "npm run build && npm run check:imports",
    "predist:win": "npm run build && npm run check:imports",
    "predist:linux": "npm run build && npm run check:imports",
    "predist:mac": "npm run build && npm run check:imports",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "keywords": [
    "electron",
    "angular",
    "terminal",
    "claude",
    "pty"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@angular/cli": "^17.3.17",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.kkrassmann.claude-powerterminal",
    "productName": "Claude PowerTerminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/src/shared/**/*",
      "src/dist/claude-powerterminal-angular/browser/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      { "from": "assets/icon.png", "to": "icon.png" }
    ],
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "kkrassmann",
      "repo": "claude-powerterminal"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "claude-powerterminal-${version}-win-x64.${ext}",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "claude-powerterminal-${version}-linux-x64.${ext}",
      "category": "Development"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "claude-powerterminal-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "identity": null
    }
  }
}
